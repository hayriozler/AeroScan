## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options
.vs/

# Rider / VS Code (optional if you use them)
.idea/
.vscode/

# ASP.NET Core / Blazor
wwwroot/dist/
wwwroot/build/
wwwroot/lib/

# Node (if using frontend tooling in Blazor)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Publish output
publish/
*.pubxml.user

# IIS / Azure
*.azurePubxml
*.publishproj

# Logs
*.log
logs/

# Entity Framework
*.dbmdl
*.jfm
*.pfx

# SQL Server files
*.mdf
*.ldf

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# DotCover
*.dotCover

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# Coverlet
coverage*.json
coverage*.xml

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# Blazor WASM specific
wwwroot/_framework/
wwwroot/service-worker-assets.js

# Environment variables
.env
.env.*

# Secrets
secrets.json
appsettings.Development.json

# Claude / AI tooling
.claude/