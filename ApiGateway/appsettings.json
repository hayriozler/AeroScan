{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-login-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/auth/login" }
      },
      "auth-logout-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/auth/logout" }
      },
      "auth-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "AuthorizationPolicy": "authenticated"
      },
      "bags-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/bags/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "dashboard-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/dashboard/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "departure-flights-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/departure/flights/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "arrival-flights-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/arrival/flights/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "companies-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/companies/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "scans-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/scans/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "reports-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/reports/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "reconciliation-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/reconciliation/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "users-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/users/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "roles-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/roles/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "permissions-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/permissions/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "audit-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/audits/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "hht-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/hht/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "containers-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/containers/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "container-types-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/container-types/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "container-classes-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/container-classes/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "airline-class-maps-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/airline-class-maps/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "resource-status-maps-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/resource-status-maps/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      },
      "system-configs-route": {
        "ClusterId": "cluster",
        "Match": { "Path": "/api/system-configs/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "api"
      }
    },
    "Clusters": {
      "cluster": {
        "Destinations": {
          "baggage-service": { "Address": "https+http://project-aeroscan" }
        }
      }
    }
  }
}
