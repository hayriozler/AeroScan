<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#1565C0</Color>
    <Color x:Key="PrimaryDark">#003c8f</Color>
    <Color x:Key="PrimaryLight">#5e92f3</Color>
    <Color x:Key="Accent">#B71C1C</Color>

    <Color x:Key="Background">#121212</Color>
    <Color x:Key="Surface">#1E1E1E</Color>
    <Color x:Key="SurfaceVariant">#2C2C2C</Color>

    <Color x:Key="OnPrimary">White</Color>
    <Color x:Key="OnBackground">#E0E0E0</Color>
    <Color x:Key="OnSurface">#BDBDBD</Color>

    <Color x:Key="MenuBlue">#1565C0</Color>
    <Color x:Key="MenuGreen">#2E7D32</Color>
    <Color x:Key="MenuOrange">#E65100</Color>
    <Color x:Key="MenuPurple">#6A1B9A</Color>
    <Color x:Key="MenuTeal">#00695C</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Error">#EF5350</Color>

    <SolidColorBrush x:Key="PrimaryBrush"    Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}" />
    <SolidColorBrush x:Key="SurfaceBrush"    Color="{StaticResource Surface}" />

</ResourceDictionary>
