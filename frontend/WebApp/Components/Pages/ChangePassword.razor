@page "/change-password"
@attribute [Authorize]
@inject AuthApiClient Api
@inject NavigationManager Nav

<PageTitle>AeroScan BRS · Change Password</PageTitle>

<div class="p-6 max-w-md">

    <h1 class="text-3xl font-extrabold tracking-tighter text-on-surface uppercase font-headline mb-8">Change Password</h1>

    <div class="bg-surface-container border-l-4 @(_success ? "border-primary-container" : "border-outline-variant") p-8 shadow-xl">

        @if (_success)
        {
            <div class="flex items-center gap-3 p-4 bg-primary-container/10 text-primary-container font-headline text-sm mb-6">
                <span class="material-symbols-outlined">check_circle</span>
                Password updated successfully.
            </div>
        }

        @if (_errorMessage is not null)
        {
            <div class="flex items-center gap-3 p-4 bg-error/10 text-error font-headline text-sm mb-6">
                <span class="material-symbols-outlined">error</span>
                @_errorMessage
            </div>
        }

        <div class="space-y-6">

            <!-- Current password -->
            <div class="space-y-2">
                <label class="block font-headline text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                    Current Password
                </label>
                <div class="relative group">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary-container transition-colors">
                        <span class="material-symbols-outlined text-lg">lock</span>
                    </div>
                    <input @bind="_currentPassword"
                           type="password"
                           autocomplete="current-password"
                           class="w-full bg-surface-container-highest border-none h-12 pl-12 pr-4 text-on-surface font-headline font-medium focus:ring-0 focus:bg-surface-bright transition-all placeholder:text-on-surface-variant/30 text-sm"
                           placeholder="••••••••" />
                    <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-primary-container group-focus-within:w-full transition-all duration-300"></div>
                </div>
            </div>

            <!-- New password -->
            <div class="space-y-2">
                <label class="block font-headline text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                    New Password
                </label>
                <div class="relative group">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary-container transition-colors">
                        <span class="material-symbols-outlined text-lg">lock_open</span>
                    </div>
                    <input @bind="_newPassword"
                           type="password"
                           autocomplete="new-password"
                           class="w-full bg-surface-container-highest border-none h-12 pl-12 pr-4 text-on-surface font-headline font-medium focus:ring-0 focus:bg-surface-bright transition-all placeholder:text-on-surface-variant/30 text-sm"
                           placeholder="Min. 8 characters" />
                    <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-primary-container group-focus-within:w-full transition-all duration-300"></div>
                </div>
            </div>

            <!-- Confirm password -->
            <div class="space-y-2">
                <label class="block font-headline text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                    Confirm New Password
                </label>
                <div class="relative group">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary-container transition-colors">
                        <span class="material-symbols-outlined text-lg">verified</span>
                    </div>
                    <input @bind="_confirmPassword"
                           type="password"
                           autocomplete="new-password"
                           class="w-full bg-surface-container-highest border-none h-12 pl-12 pr-4 text-on-surface font-headline font-medium focus:ring-0 focus:bg-surface-bright transition-all placeholder:text-on-surface-variant/30 text-sm"
                           placeholder="••••••••" />
                    <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-primary-container group-focus-within:w-full transition-all duration-300"></div>
                </div>
            </div>

            <button @onclick="SubmitAsync"
                    disabled="@_submitting"
                    class="w-full bg-primary-container text-on-primary-fixed font-headline font-bold py-4 uppercase tracking-widest hover:bg-primary-dim transition-all active:scale-[0.98] flex items-center justify-center gap-3">
                @if (_submitting)
                {
                    <span class="material-symbols-outlined animate-spin">refresh</span>
                    <span>Updating...</span>
                }
                else
                {
                    <span>Update Password</span>
                    <span class="material-symbols-outlined">lock_reset</span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _submitting;
    private bool _success;
    private string? _errorMessage;

    private async Task SubmitAsync()
    {
        _errorMessage = null;
        _success = false;

        if (string.IsNullOrWhiteSpace(_currentPassword))
        {
            _errorMessage = "Please enter your current password.";
            return;
        }
        if (_newPassword.Length < 8)
        {
            _errorMessage = "New password must be at least 8 characters.";
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            _errorMessage = "New passwords do not match.";
            return;
        }

        _submitting = true;

        var ok = await Api.ChangePasswordAsync(_currentPassword, _newPassword);

        _submitting = false;

        if (ok)
        {
            _success = true;
            _currentPassword = _newPassword = _confirmPassword = string.Empty;
        }
        else
        {
            _errorMessage = "Failed to update password. Please check your current password and try again.";
        }
    }
}
